# Use 'postgres' if running via `docker compose run app`
# Use 'localhost' if running natively via `python -m build_your_own_rag.cli`
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rag_db
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=rag_password
EMBEDDING_MODEL_NAME=BAAI/bge-base-en-v1.5
CHUNK_TARGET_TOKENS=350
CHUNK_OVERLAP_TOKENS=50
# Average tokens per word for the embedding model. Used to convert
# CHUNK_TARGET_TOKENS to a word count. Default 1.3 for English + bge-base-en-v1.5.
WORD_TOKEN_RATIO=1.3
DEFAULT_EXTRACTION_STRATEGY=FAST
RRF_K=60
# Use 'http://host.docker.internal:11434' if running via `docker compose run app` on Mac/Windows
# Use 'http://localhost:11434' if running natively via `python -m build_your_own_rag.cli`
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=granite3.3:8b
OLLAMA_TEMPERATURE=0.3
